<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Anthropic</id>
    <version>12.23.0</version>
    <authors>Anthropic</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>logo.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://docs.anthropic.com/claude/reference/</projectUrl>
    <description>The official .NET library for the Anthropic API.</description>
    <copyright>Copyright 2026 Anthropic</copyright>
    <tags>sdk api http library</tags>
    <repository type="git" url="https://www.github.com/anthropics/anthropic-sdk-csharp" branch="refs/heads/main" commit="7878c5fd9fa8059e1aab70e357ad44a11eeba65b" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Microsoft.Extensions.AI.Abstractions" version="10.5.1" exclude="Build,Analyzers" />
        <dependency id="System.Net.ServerSentEvents" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="10.0.6" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="Microsoft.Extensions.AI.Abstractions" version="10.5.1" exclude="Build,Analyzers" />
        <dependency id="System.Net.ServerSentEvents" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="10.0.6" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Extensions.AI.Abstractions" version="10.5.1" exclude="Build,Analyzers" />
        <dependency id="System.Collections.Immutable" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="System.Net.ServerSentEvents" version="10.0.1" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="10.0.6" exclude="Build,Analyzers" />
        <dependency id="System.Threading.Tasks.Extensions" version="4.6.3" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>